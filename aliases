# include .config/alias in *shrc 
# [ -f $HOME/.config/aliases ] && . $HOME/.config/aliases

[[ -d /opt/homebrew/opt/ccache/libexec ]] && export PATH=/opt/homebrew/opt/ccache/libexec:$PATH
[[ -s /usr/share/nvm/init-nvm.sh ]] && \. /usr/share/nvm/init-nvm.sh
[[ -d ~/.local/bin ]] && export PATH=~/.local/bin:$PATH
command -v pacman >/dev/null && spac() { sudo pacman -Syu --noconfirm "$@"; }
command -v yay >/dev/null && syay() { yay -Syu --noconfirm "$@"; }

# Use a compatible TERM when SSHing to remote devices that don't know xterm-ghostty
# Skip override for Windows hosts which handle TERM differently
ssh() {
    local host="$1"
    case "$host" in
        t1) command ssh "$@" ;;
        *) TERM=xterm-256color command ssh "$@" ;;
    esac
}

# Lazy Loading Thefuck
fuck() {
    unset -f fuck
    eval "$(thefuck --alias)"
    fuck "$@"
}
# send all __pycache__ folders to /tmp
export PYTHONPYCACHEPREFIX=/tmp

eval "$(starship init zsh)"

command -v go >/dev/null && export PATH="$(go env GOPATH)/bin:$PATH"
command -v yarn >/dev/null && export PATH="$(yarn global bin):$PATH"

alias cd..='cd ..'
alias cd....='cd ../../..'
alias cd...='cd ../..'
alias ve='source .venv/bin/activate'
alias py='uv run python'
alias serve='uv run python -m http.server'
alias clera='clear'
alias uvim='uv run nvim'
alias v='nvim'
alias sv='sudo nvim'
alias u="uv run"
alias upg="uv lock --upgrade"
src() { source "$HOME/.${SHELL##*/}rc"; }

command -v delta >/dev/null && d() { delta -s --dark --hyperlinks "$@"; }

command -v brew >/dev/null && {
  NVM_PREFIX=$(brew --prefix nvm)
  [[ -s "$NVM_PREFIX/nvm.sh" ]] && \. "$NVM_PREFIX/nvm.sh"
  [[ -s "$NVM_PREFIX/etc/bash_completion.d/nvm" ]] && \. "$NVM_PREFIX/etc/bash_completion.d/nvm"
}

alias opa='opencode attach ai.home.lals.ca:4096'
alias opaa='opencode attach ai.home.lals.ca:4444'
alias opgo='opencode attach gobot1.home.lals.ca:4096'
alias opgoo='opencode attach gobot1.home.lals.ca:4444'

opc() {
    opencode attach $1:4096
}

opcc() {
    opencode attach $1:4444
}

rmux() {
    ssh -t "$1" "tmux -u a || tmux -u new"
}
